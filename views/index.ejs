<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>mini wp</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h3>All chats </h3>
    <form method="GET" action="/chats/new">
        <button>New Chat</button>
    </form>
    <br>
   <%  for(let chat of chats){ %>
    <div class="chat">
        <p>
            from: <i><%= chat.from %></i>
        </p>
        <div class="msg">
         <p>
           msg: <%= chat.message %>
           <form method="get" action="/chats/<%=chat._id%>/edit">
            <button>edit</button>
           </form>
           <br>
           <form method="post" action="/chats/<%=chat._id%>?_method=delete">
            <button>delete</button>
           </form>
        </p>
        </div>
        
        <p>
               <i>  to: <%= chat.to %></i>
        </p>
        <hr>
        <p>
            <%= chat.created_at.toString().split(" ")[4]%>

        </p>
        <p>
            <%= chat.created_at.toString().split(" ").slice(0,4).join(" ")%>
            
        </p>
    </div>
  
    <br><br>
<% } %>
</body>
</html>

